{
  "name": "rv-management-frontend",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "axios": "^0.18.1",
    "node-sass-chokidar": "^0.0.3",
    "npm-run-all": "^4.1.2",
    "prop-types": "^15.6.0",
    "react": "^16.12.0",
    "react-dom": "^16.12.0",
    "react-flexbox-grid": "^2.0.0",
    "react-redux": "^7.1.3",
    "react-router-dom": "^5.1.2",
    "react-scripts": "^3.3.0",
    "react-transition-group": "^2.2.1",
    "redux": "^4.0.0",
    "redux-devtools-extension": "^2.13.8",
    "redux-form": "^8.2.6",
    "redux-thunk": "^2.2.0",
    "uuid": "^3.2.1"
  },
  "engines": {
    "node": ">=8.9.0"
  },
  "scripts": {
    "start": "react-scripts start",
    "lint-js": "eslint src/**/*.{js,jsx}",
    "fix-js": "eslint --fix src/**/*.{js,jsx}",
    "build-js": "react-scripts build",
    "build": "npm-run-all build-css build-js",
    "build-css": "node-sass-chokidar --include-path ./src --include-path ./node_modules src/ -o src/",
    "watch-css": "npm run build-css && node-sass-chokidar --include-path ./src --include-path ./node_modules src/ -o src/ --watch --recursive",
    "lint-css": "stylelint src/**/*.scss --syntax=scss",
    "fix-css": "stylelint src/**/*.scss --syntax=scss --fix",
    "test": "react-scripts test --env=jsdom",
    "eject": "react-scripts eject",
    "storybook": "start-storybook -p 9009 -s public",
    "build-storybook": "build-storybook -s public",
    "styleguide-task": "styleguidist server",
    "styleguide-task:build": "styleguidist build",
    "styleguide": "npm-run-all -p watch-css styleguide-task",
    "stylehuide:build": "npm-run-all build-css styleguide-task:build"
  },
  "devDependencies": {
    "@storybook/addon-actions": "^3.3.10",
    "@storybook/addon-links": "^3.3.10",
    "@storybook/addons": "^3.3.10",
    "@storybook/react": "^3.3.10",
    "dotenv": "^5.0.0",
    "enzyme": "^3.3.0",
    "enzyme-adapter-react-16": "^1.1.1",
    "eslint-plugin-sort-imports-es6-autofix": "0.3.0",
    "husky": "^3.1.0",
    "lint-staged": "^6.1.0",
    "prettier": "^1.19.1",
    "prettier-eslint": "^9.0.1",
    "prettier-stylelint": "^0.4.2",
    "react-styleguidist": "^6.2.2",
    "react-test-renderer": "^16.2.0",
    "redux-immutable-state-invariant": "^2.1.0",
    "redux-mock-store": "^1.5.1",
    "stylelint": "^8.4.0",
    "stylelint-config-standard": "^18.0.0"
  },
  "jest": {
    "collectCoverageFrom": [
      "**/*.{js,jsx}",
      "!**/node_modules/**",
      "!**/src/stories/**",
      "!**/coverage/**",
      "!**/src/index.js"
    ]
  },
  "browserslist": [
    ">0.2%",
    "not dead",
    "not ie <= 11",
    "not op_mini all"
  ]
}
